# Environment Configuration
# Copy this file to .env and fill in your values.

# ── LLM Backend ───────────────────────────────────────────────────────────────
# groq   → Use Groq API (fast, cloud, requires API key)
# local  → Use google/flan-t5-base offline (zero-cost, downloads once ~250 MB)
LLM_MODE=groq

# ── Groq API (required if LLM_MODE=groq) ─────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Asana Task Tracker (optional) ────────────────────────────────────────────
# Get your PAT from: https://app.asana.com/0/developer-console
ASANA_PAT=your_asana_personal_access_token_here
ASANA_PROJECT_GID=your_asana_project_gid_here
